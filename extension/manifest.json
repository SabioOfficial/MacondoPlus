{
  "manifest_version": 3,
  "name": "Macondo+",
  "version": "1.1.0",
  "description": "A QoL-focused browser extension for Macondo.",
  "icons": {
    "16": "images/icon-16.png",
    "24": "images/icon-24.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*.png", "images/*.jpg", "images/*.webp"],
      "matches": ["https://macondo.hackclub.com/*"]
    }
  ],
  "content_scripts": [
    {
      "js": [
        "scripts/content-script.js",
        "scripts/modules/hide-feedback.js",
        "scripts/modules/better-page-titles.js",
        "scripts/modules/dark-mode.js",
        "scripts/modules/module-manager.js",
        "scripts/modules/keyboard-shortcuts.js",
        "scripts/modules/middle-click-project.js",
        "scripts/modules/hide-idea-generator.js",
        "scripts/modules/shop-goals.js",
        "scripts/modules/streak-time-display.js",
        "scripts/modules/styling-fixes.js",
        "scripts/modules/streak-intensity.js",
        "scripts/modules/macondoplus-styles.js",
        "scripts/modules/shop-categories.js",
        "scripts/modules/macondoplus-panel.js",
        "scripts/modules/achievements.js",
        "scripts/modules/shop-sort-enhanced.js",
        "scripts/modules/additional-project-info.js",
        "scripts/modules/deforestation.js",
        "scripts/modules/traditional.js",
        "scripts/modules/rich-pretender.js",
        "scripts/modules/in-debt.js",
        "scripts/modules/extra-fruity-badge.js",
        "scripts/modules/new-project-addict.js",
        "scripts/modules/drunk.js",
        "scripts/modules/ads-please.js",
        "scripts/modules/googentitys-module.js",
        "scripts/modules/gambling.js",
        "scripts/modules/retro.js"
      ],
      "matches": [
        "https://macondo.hackclub.com/*"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://api.github.com/*", "https://clients2.google.com/*", "https://addons.mozilla.org/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "macondoplus@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}